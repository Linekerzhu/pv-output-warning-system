# 和风天气API配置
QWEATHER_API_KEY=your_api_key_here
QWEATHER_API_HOST=https://devapi.qweather.com
QWEATHER_CREDENTIAL_ID=your_credential_id

# 金山地区中心坐标
LOCATION_LAT=30.7413
LOCATION_LON=121.3420
LOCATION_NAME=上海金山

# 预警阈值（出力下降比例）
WARNING_LEVEL_BLUE=0.30
WARNING_LEVEL_YELLOW=0.50
WARNING_LEVEL_ORANGE=0.70
WARNING_LEVEL_RED=0.85

# 有效发电时段
GENERATION_START_HOUR=9
GENERATION_END_HOUR=16

# 轮询间隔（秒），默认1小时
POLL_INTERVAL_SECONDS=3600

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
